# Buccaneer toolchain build artifacts (root-owned by Docker)
src/buccaneer/build/
src/buccaneer/bin/

# Backups
backups/
dist/releases/

# OS and editor noise
.DS_Store
.DS_Store?
Thumbs.db
*.swp
*.swo
*~
*.orig
*.bak
.vscode/
.idea/
*.sublime-workspace

