	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_tools.dir/build.make CMakeFiles/test_tools.dir/tests/test_tools.c.i
.PHONY : tests/test_tools.c.i

tests/test_tools.s: tests/test_tools.c.s
.PHONY : tests/test_tools.s

# target to generate assembly for a file
tests/test_tools.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_tools.dir/build.make CMakeFiles/test_tools.dir/tests/test_tools.c.s
.PHONY : tests/test_tools.c.s

