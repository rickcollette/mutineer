#!/usr/bin/expect -f
# Time bank tests for Mutineer BBS

set script_dir [file dirname [info script]]
source "$script_dir/expect_helpers.exp"

puts ""
puts "=== Time Bank Tests ==="
puts ""

# Test 1: Access time bank
run_test "access_timebank" {
    if {![connect_bbs]} { return 0 }
    if {![login_as "sysop" "mutineer"]} { return 0 }
    
    send "T\r"
    
    expect {
        -re "Time bank|Deposit|Withdraw|Balance|minutes" { }
        "restricted" {
            send "Q\r"
            expect eof
            return 0
        }
        timeout { return 0 }
    }
    
    # Cancel/exit
    send "Q\r"
    
    expect {
        "Selection:" { }
        -re "Deposit|Withdraw" {
            send "0\r"
            exp_continue
        }
        timeout { }
    }
    
    expect {
        "Selection:" { }
        timeout { }
    }
    
    send "Q\r"
    expect eof
    return 1
}

# Test 2: Check time bank balance
run_test "check_balance" {
    if {![connect_bbs]} { return 0 }
    if {![login_as "sysop" "mutineer"]} { return 0 }
    
    send "T\r"
    
    expect {
        -re "Balance:|minutes|Time bank" { }
        timeout { return 0 }
    }
    
    # Look for balance display
    expect {
        -re "\\d+ min|Balance" { }
        -re "Deposit|Withdraw" { }
        timeout { }
    }
    
    send "Q\r"
    
    expect {
        "Selection:" { }
        -re "Deposit|Withdraw" {
            send "0\r"
            exp_continue
        }
        timeout { }
    }
    
    expect {
        "Selection:" { }
        timeout { }
    }
    
    send "Q\r"
    expect eof
    return 1
}

# Test 3: Deposit time
run_test "deposit_time" {
    if {![connect_bbs]} { return 0 }
    if {![login_as "sysop" "mutineer"]} { return 0 }
    
    send "T\r"
    
    # Wait for the full prompt
    expect {
        -re {\(D\)eposit.*\(W\)ithdraw\?} { }
        timeout { return 0 }
    }
    
    # Try to deposit
    send "D\r"
    
    expect {
        -re "deposit:|Amount|How many" { }
        timeout { return 0 }
    }
    
    send "5\r"
    
    expect {
        -re "balance:|Selection:" { }
        timeout { return 0 }
    }
    
    # May already be at menu or need to quit
    expect {
        "Selection:" { }
        timeout { }
    }
    
    send "Q\r"
    expect {
        eof { }
        timeout { }
    }
    catch { close }
    catch { wait }
    return 1
}

# Test 4: Withdraw time
run_test "withdraw_time" {
    if {![connect_bbs]} { return 0 }
    if {![login_as "sysop" "mutineer"]} { return 0 }
    
    send "T\r"
    
    # Wait for the full prompt
    expect {
        -re {\(D\)eposit.*\(W\)ithdraw\?} { }
        timeout { return 0 }
    }
    
    # Try to withdraw
    send "W\r"
    
    expect {
        -re "withdraw:|Amount|How many|insufficient" { }
        timeout { return 0 }
    }
    
    send "1\r"
    
    expect {
        -re "balance:|insufficient|Selection:" { }
        timeout { return 0 }
    }
    
    # May already be at menu or need to quit
    expect {
        "Selection:" { }
        timeout { }
    }
    
    send "Q\r"
    expect {
        eof { }
        timeout { }
    }
    catch { close }
    catch { wait }
    return 1
}

# Print summary and exit
set exit_code [test_summary "test_timebank.exp"]
exit $exit_code
