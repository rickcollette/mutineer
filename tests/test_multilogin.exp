#!/usr/bin/expect -f
# Test multi-login prevention

source [file dirname [info script]]/expect_helpers.exp

set timeout 10

proc login_sysop_local {} {
    global default_host default_port timeout
    spawn telnet $default_host $default_port
    expect {
        -re "Connected to" { }
        timeout { return "" }
    }
    set sid $spawn_id
    expect {
        -re "ANSI.*\\?|graphics.*\\?" { send "Y\r" }
        timeout { catch { close -i $sid }; return "" }
    }
    expect {
        "Handle:" { send "sysop\r" }
        timeout { catch { close -i $sid }; return "" }
    }
    expect {
        "Password:" { send "mutineer\r" }
        timeout { catch { close -i $sid }; return "" }
    }
    expect {
        "Selection:" { return $sid }
        timeout { catch { close -i $sid }; return "" }
    }
}

set session1 [login_sysop_local]
if {$session1 eq ""} {
    puts "\n\[FAIL\] Could not establish first login"
    exit 1
}

spawn telnet $default_host $default_port
set session2 $spawn_id
expect {
    -re "Connected to" { }
    timeout { puts "\n\[FAIL\] Could not connect second session"; exit 1 }
}
expect {
    -re "ANSI.*\\?|graphics.*\\?" { send "Y\r" }
    timeout { puts "\n\[FAIL\] No ANSI prompt for second session"; exit 1 }
}
expect {
    "Handle:" { send "sysop\r" }
    timeout { puts "\n\[FAIL\] No handle prompt for second session"; exit 1 }
}
expect {
    "Password:" { send "mutineer\r" }
    timeout { puts "\n\[FAIL\] No password prompt for second session"; exit 1 }
}

expect {
    "already logged in" {
        puts "\n\[PASS\] Multi-login correctly blocked"
    }
    "Selection:" {
        puts "\n\[FAIL\] Multi-login was allowed"
        exit 1
    }
    timeout {
        puts "\n\[FAIL\] Timeout waiting for multi-login response"
        exit 1
    }
}

expect {
    "Goodbye" { }
    eof { }
    timeout { }
}
catch { close -i $session2 }
catch { wait -i $session2 }

set spawn_id $session1
send "Q\r"
expect {
    eof { }
    timeout { catch { close -i $session1 } }
}
catch { wait -i $session1 }

puts "\n\[PASS\] Multi-login prevention test passed"
exit 0
