#!/usr/bin/expect -f
# Chat loop sanity
set timeout 10
set host "127.0.0.1"
set port 2929
spawn telnet $host $port
expect "Handle:"
send "sysop\r"
expect "Password:"
send "mutineer\r"
expect "Selection:"
send "C\r"
expect "Channel"
send "\r"
expect "> "
send "hello world\r"
send "/quit\r"
expect "Selection:"
send "Q\r"
expect eof
