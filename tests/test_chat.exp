#!/usr/bin/expect -f
# Focused chat smoke test for Mutineer BBS.

set script_dir [file dirname [info script]]
source "$script_dir/expect_helpers.exp"

puts ""
puts "=== Chat Feature Tests ==="
puts ""

run_test "enter_send_exit_chat" {
    if {![connect_bbs]} { return 0 }
    if {![login_as "sysop" "mutineer"]} { return 0 }

    send "C\r"
    expect {
        -re "Channel.*:" { send "\r" }
        "> " { }
        "restricted" { return 0 }
        timeout { return 0 }
    }

    expect {
        "> " { }
        timeout { return 0 }
    }

    send "Hello from expect test!\r"
    expect {
        "> " { }
        timeout { return 0 }
    }

    send "/quit\r"
    expect {
        "Selection:" { }
        -re "Leaving chat" {
            expect {
                "Selection:" { }
                timeout { return 0 }
            }
        }
        timeout { return 0 }
    }

    send "Q\r"
    expect {
        eof { }
        timeout { return 0 }
    }
    return 1
}

set exit_code [test_summary "test_chat.exp"]
exit $exit_code
