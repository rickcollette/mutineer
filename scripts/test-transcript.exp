#!/usr/bin/expect -f
set timeout 30
set transcript ""
spawn telnet 127.0.0.1 2929
expect -re {ANSI graphics}
append transcript $expect_out(buffer)
send "Y\r"
expect -re {Handle:}
append transcript $expect_out(buffer)
set tmpdir [expr {[info exists env(TMPDIR)] && $env(TMPDIR) ne "" ? $env(TMPDIR) : "/tmp"}]
set fd [open [file join $tmpdir transcript.[pid].ansi] w]
puts -nonewline $fd $transcript
close $fd
puts "len=[string length $transcript]"
