#!/bin/bash
# Check for updates, backup, download, and migrate Mutineer BBS
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BBS_ROOT="$(dirname "$SCRIPT_DIR")"
BBS_DIR="$BBS_ROOT/dist"

# Configuration - adjust these for your setup
UPDATE_URL="${MUTINEER_UPDATE_URL:-https://github.com/yourusername/mutineer/releases/latest/download}"
VERSION_FILE="$BBS_DIR/VERSION"
CURRENT_VERSION="unknown"

if [ -f "$VERSION_FILE" ]; then
    CURRENT_VERSION=$(cat "$VERSION_FILE")
fi

echo "Mutineer Update Utility"
echo "======================="
echo "Current version: $CURRENT_VERSION"
echo ""

# Check for new version
check_version() {
    echo "Checking for updates..."
    
    # Try to fetch latest version info
    LATEST_VERSION=$(curl -sL "$UPDATE_URL/VERSION" 2>/dev/null || echo "")
    
    if [ -z "$LATEST_VERSION" ]; then
        echo "Could not check for updates. Network error or URL not configured."
        echo "Set MUTINEER_UPDATE_URL environment variable to your release URL."
        return 1
    fi
    
    echo "Latest version: $LATEST_VERSION"
    
    if [ "$CURRENT_VERSION" = "$LATEST_VERSION" ]; then
        echo "You are running the latest version."
        return 1
    fi
    
    echo "New version available!"
    return 0
}

# Download and install update
do_update() {
    echo ""
    echo "Starting update process..."
    
    # Step 1: Backup current installation
    echo ""
    echo "Step 1: Creating backup..."
    "$SCRIPT_DIR/backup"
    
    # Step 2: Stop BBS if running
    echo ""
    echo "Step 2: Stopping BBS..."
    "$SCRIPT_DIR/stop" || true
    
    # Step 3: Download new version
    echo ""
    echo "Step 3: Downloading update..."
    TEMP_DIR=$(mktemp -d)
    trap "rm -rf $TEMP_DIR" EXIT
    
    if ! curl -sL "$UPDATE_URL/mutineer-linux-x64.tar.gz" -o "$TEMP_DIR/update.tar.gz"; then
        echo "Error: Failed to download update"
        exit 1
    fi
    
    # Step 4: Extract and verify
    echo "Step 4: Extracting..."
    cd "$TEMP_DIR"
    tar -xzf update.tar.gz
    
    if [ ! -f "$TEMP_DIR/mutineer" ]; then
        echo "Error: Invalid update package"
        exit 1
    fi
    
    # Step 5: Install new binary
    echo "Step 5: Installing..."
    cp "$TEMP_DIR/mutineer" "$BBS_DIR/mutineer.new"
    chmod +x "$BBS_DIR/mutineer.new"
    mv "$BBS_DIR/mutineer" "$BBS_DIR/mutineer.old"
    mv "$BBS_DIR/mutineer.new" "$BBS_DIR/mutineer"
    
    # Update version file
    if [ -f "$TEMP_DIR/VERSION" ]; then
        cp "$TEMP_DIR/VERSION" "$VERSION_FILE"
    fi
    
    # Step 6: Run migrations if any
    echo "Step 6: Running migrations..."
    if [ -f "$TEMP_DIR/migrate.sql" ]; then
        echo "  Applying database migrations..."
        sqlite3 "$BBS_DIR/data/mutineer.db" < "$TEMP_DIR/migrate.sql"
    fi
    
    # Copy any new/updated assets
    for dir in art menus sql; do
        if [ -d "$TEMP_DIR/$dir" ]; then
            echo "  Updating $dir..."
            cp -rn "$TEMP_DIR/$dir/"* "$BBS_DIR/$dir/" 2>/dev/null || true
        fi
    done
    
    # Cleanup old binary
    rm -f "$BBS_DIR/mutineer.old"
    
    echo ""
    echo "Update complete!"
    echo "New version: $(cat "$VERSION_FILE" 2>/dev/null || echo 'unknown')"
    echo ""
    echo "Start the BBS with: $SCRIPT_DIR/start-screen"
}

# Main
case "${1:-check}" in
    check)
        check_version
        ;;
    install|update)
        if check_version; then
            read -p "Proceed with update? [y/N] " confirm
            if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
                do_update
            else
                echo "Update cancelled."
            fi
        fi
        ;;
    force)
        do_update
        ;;
    *)
        echo "Usage: $0 [check|install|force]"
        echo "  check   - Check for new version (default)"
        echo "  install - Check and install if available"
        echo "  force   - Force reinstall/update"
        exit 1
        ;;
esac
